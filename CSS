body {
    font-family: Arial, sans-serif;
    max-width: 800px;
    margin: auto;
    padding: 20px;
    background: #f5f5f5;
}

h1 {
    color: #2563eb;
}

.card {
    background: white;
    padding: 15px;
    margin-top: 10px;
    border-radius: 10px;
}

button {
    padding: 10px 20px;
    margin-right: 10px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
}
